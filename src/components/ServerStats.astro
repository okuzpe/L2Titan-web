---
const stats = [
  { label: 'Jugadores Online', value: '1,245', icon: '👥' },
  { label: 'PvP Totales', value: '15,402', icon: '⚔️' },
  { label: 'PK Totales', value: '3,291', icon: '☠️' },
  { label: 'Clanes Activos', value: '42', icon: '🛡️' },
];
---

<section class="py-12 bg-black/50 border-y border-white/5 backdrop-blur-sm">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
      {stats.map((stat) => (
        <div class="text-center group hover:transform hover:scale-105 transition-all duration-300">
          <div class="text-4xl mb-2 group-hover:animate-bounce">{stat.icon}</div>
          <div class="text-3xl md:text-4xl font-bold text-white mb-1 font-display tracking-wider">{stat.value}</div>
          <div class="text-sm text-yellow-500 uppercase tracking-widest font-semibold">{stat.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>
