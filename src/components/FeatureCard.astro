---
import CardSurface from "./ui/CardSurface.astro";

interface Props {
  title: string;
  description: string;
  icon: string;
  titleKey?: string;
  descriptionKey?: string;
}

const { title, description, icon, titleKey, descriptionKey } = Astro.props;
---

<CardSurface className="p-6 md:p-7 hover:border-yellow-500/30 transition-colors duration-300 group">
  <div class="w-11 h-11 bg-yellow-500/10 rounded-lg flex items-center justify-center mb-4 text-xl text-yellow-500 border border-yellow-500/20">
    {icon}
  </div>
  <h3 class="text-lg md:text-xl df-title mb-2">
    {titleKey ? <span data-i18n={titleKey}>{title}</span> : title}
  </h3>
  <p class="text-gray-400 text-sm leading-relaxed">
    {descriptionKey ? <span data-i18n={descriptionKey}>{description}</span> : description}
  </p>
</CardSurface>
