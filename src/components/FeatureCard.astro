---
interface Props {
  title: string;
  description: string;
  icon: string;
  titleKey?: string;
  descriptionKey?: string;
}

const { title, description, icon, titleKey, descriptionKey } = Astro.props;
---

<div class="p-6 bg-gradient-to-br from-slate-900 to-slate-950 rounded-xl border border-white/10 hover:border-yellow-500/50 transition-all duration-300 hover:shadow-xl hover:shadow-yellow-500/5 group">
  <div class="w-12 h-12 bg-yellow-500/10 rounded-lg flex items-center justify-center mb-4 text-2xl group-hover:scale-110 transition-transform duration-300 text-yellow-500">
    {icon}
  </div>
  <h3 class="text-xl font-bold text-white mb-2 font-display">
    {titleKey ? <span data-i18n={titleKey}>{title}</span> : title}
  </h3>
  <p class="text-gray-400 text-sm leading-relaxed">
    {descriptionKey ? <span data-i18n={descriptionKey}>{description}</span> : description}
  </p>
</div>
