---
const news = [
  {
    title: "Gran Apertura: L2Titan",
    titleKey: "news.items.opening.title",
    date: "23 Nov 2025",
    summary:
      "Prepárate para la experiencia definitiva. Servidor Interlude x30 con características únicas.",
    summaryKey: "news.items.opening.summary",
    image: "/images/news-1.png",
  },
  {
    title: "Evento: Asedio al Castillo",
    titleKey: "news.items.siege.title",
    date: "25 Nov 2025",
    summary:
      "El primer asedio está programado. ¿Quién conquistará Aden? Recompensas exclusivas para los ganadores.",
    summaryKey: "news.items.siege.summary",
    image: "/images/news-2.png",
  },
  {
    title: "Actualización de Balance",
    titleKey: "news.items.balance.title",
    date: "20 Nov 2025",
    summary:
      "Ajustes en clases de dagueros y arqueros para mejorar el PvP competitivo.",
    summaryKey: "news.items.balance.summary",
    image: "/images/news-3.png",
  },
];
---

<section class="py-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2
      class="text-4xl font-bold text-center text-yellow-500 mb-12 font-display uppercase tracking-widest"
      style="text-shadow: 0 0 20px rgba(255, 215, 0, 0.2);"
      data-i18n="news.title"
    >
      Últimas Noticias
    </h2>

    <div class="grid md:grid-cols-3 gap-8">
      {
        news.map((item) => (
          <article class="bg-slate-900/50 rounded-xl overflow-hidden border border-white/10 hover:border-yellow-500/50 transition-all duration-300 group hover:shadow-2xl hover:shadow-yellow-500/10">
            <div class="h-48 overflow-hidden">
              <img
                src={item.image}
                alt={item.title}
                class="w-full h-full object-cover transform group-hover:scale-110 transition-transform duration-500"
              />
            </div>
            <div class="p-6">
              <div class="text-yellow-500 text-xs font-bold uppercase tracking-wider mb-2">
                {item.date}
              </div>
              <h3 class="text-xl font-bold text-white mb-3 font-display group-hover:text-yellow-400 transition-colors">
                {item.titleKey ? <span data-i18n={item.titleKey}>{item.title}</span> : item.title}
              </h3>
              <p class="text-gray-400 text-sm leading-relaxed">
                {item.summaryKey ? <span data-i18n={item.summaryKey}>{item.summary}</span> : item.summary}
              </p>
              <a
                href="#"
                class="inline-block mt-4 text-yellow-500 hover:text-white text-sm font-bold uppercase tracking-wider transition-colors"
                data-i18n="news.readMore"
              >
                Leer más →
              </a>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
