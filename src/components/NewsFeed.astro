---
import { orderedNews } from '../data/news';
import CardSurface from './ui/CardSurface.astro';
import SectionHeading from './ui/SectionHeading.astro';
---

<section class="py-14 md:py-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <SectionHeading text="Últimas Noticias" i18nKey="news.title" className="mb-10" />

    <div class="max-w-6xl mx-auto">
      <div class="relative">
        <div class="overflow-hidden rounded-2xl" id="news-carousel">
          <div id="news-track" class="flex transition-transform duration-500 ease-out">
            {
              orderedNews.map((item) => (
                <article class="news-slide shrink-0">
                  <div class="px-2 h-full">
                    <CardSurface className="overflow-hidden hover:border-yellow-500/30 transition-colors duration-300 group h-full flex flex-col">
                      <div class="h-52 overflow-hidden">
                        <img
                          src={item.image}
                          alt={`${item.title} - L2Titan Lineage 2 Interlude`}
                          width="960"
                          height="224"
                          loading="lazy"
                          class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-500"
                        />
                      </div>
                      <div class="p-5 grow flex flex-col">
                        <div class="text-yellow-500 text-xs font-bold uppercase tracking-wider mb-2">
                          {item.date}
                        </div>
                        <h3 class="text-lg md:text-xl font-bold text-white mb-3 font-display uppercase tracking-wide group-hover:text-yellow-400 transition-colors">
                          {item.titleKey ? <span data-i18n={item.titleKey}>{item.title}</span> : item.title}
                        </h3>
                        <p class="text-gray-400 text-sm leading-relaxed grow">
                          {item.summaryKey ? <span data-i18n={item.summaryKey}>{item.summary}</span> : item.summary}
                        </p>
                        <a
                          href={`/news/${item.slug}`}
                          class="inline-block mt-4 text-yellow-500 hover:text-yellow-300 text-xs md:text-sm font-bold uppercase tracking-wider transition-colors"
                          data-i18n="news.readMore"
                        >
                          Leer más →
                        </a>
                      </div>
                    </CardSurface>
                  </div>
                </article>
              ))
            }
          </div>
        </div>

        <button
          id="news-prev"
          aria-label="Noticia anterior"
          class="absolute left-0 top-1/2 -translate-y-1/2 -translate-x-4 md:-translate-x-6 w-10 h-10 rounded-full bg-black/70 border border-white/20 text-white hover:text-yellow-400 hover:border-yellow-500/40 transition-colors"
        >
          ‹
        </button>
        <button
          id="news-next"
          aria-label="Siguiente noticia"
          class="absolute right-0 top-1/2 -translate-y-1/2 translate-x-4 md:translate-x-6 w-10 h-10 rounded-full bg-black/70 border border-white/20 text-white hover:text-yellow-400 hover:border-yellow-500/40 transition-colors"
        >
          ›
        </button>
      </div>

      <div id="news-dots" class="flex items-center justify-center gap-2 mt-5">
        
      </div>
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    const track = document.getElementById('news-track');
    const prevBtn = document.getElementById('news-prev');
    const nextBtn = document.getElementById('news-next');
    const dotsRoot = document.getElementById('news-dots');
    if (!track || !prevBtn || !nextBtn || !dotsRoot) return;

    const slides = Array.from(track.querySelectorAll('.news-slide'));
    let current = 0;
    let cardsPerView = 1;
    let maxIndex = Math.max(0, slides.length - cardsPerView);
    let dots = [];
    let isInitialSetup = true;

    function getCardsPerView() {
      if (window.innerWidth >= 1024) return 3;
      if (window.innerWidth >= 640) return 2;
      return 1;
    }

    function buildDots() {
      dotsRoot.innerHTML = '';
      const pages = Math.max(1, maxIndex + 1);
      for (let i = 0; i < pages; i += 1) {
        const btn = document.createElement('button');
        btn.className = `w-2.5 h-2.5 rounded-full transition-all ${i === current ? 'bg-yellow-500' : 'bg-white/30 hover:bg-white/50'}`;
        btn.setAttribute('aria-label', `Ir a grupo ${i + 1}`);
        btn.addEventListener('click', function () {
          current = i;
          update();
        });
        dotsRoot.appendChild(btn);
      }
      dots = Array.from(dotsRoot.querySelectorAll('button'));
    }

    function setupResponsive() {
      cardsPerView = getCardsPerView();
      slides.forEach((slide) => {
        slide.style.flexBasis = `${100 / cardsPerView}%`;
      });
      maxIndex = Math.max(0, slides.length - cardsPerView);
      if (isInitialSetup) {
        current = maxIndex;
        isInitialSetup = false;
      } else if (current > maxIndex) {
        current = maxIndex;
      }
      buildDots();
    }

    function update() {
      track.style.transform = `translateX(-${current * (100 / cardsPerView)}%)`;
      dots.forEach((dot, i) => {
        if (i === current) {
          dot.classList.remove('bg-white/30', 'hover:bg-white/50');
          dot.classList.add('bg-yellow-500');
        } else {
          dot.classList.remove('bg-yellow-500');
          dot.classList.add('bg-white/30', 'hover:bg-white/50');
        }
      });
    }

    prevBtn.addEventListener('click', function () {
      current = current <= 0 ? maxIndex : current - 1;
      update();
    });

    nextBtn.addEventListener('click', function () {
      current = current >= maxIndex ? 0 : current + 1;
      update();
    });

    window.addEventListener('resize', function () {
      setupResponsive();
      update();
    });

    setupResponsive();
    update();
  })();
</script>
