---
import {
  enchantGeneral,
  normalScrollWeaponArmor,
  normalScrollJewelry,
  blessedScrollWeaponArmor,
  blessedScrollJewelry,
  crystalScrollWeaponArmor,
  crystalScrollJewelry,
  soulCrystals,
  augmentation,
} from '../../data/serverInfo';

function getCellBg(chance: number): string {
  if (chance >= 90) return 'bg-green-500/20 text-green-400 border-green-500/30';
  if (chance >= 70) return 'bg-yellow-500/15 text-yellow-400 border-yellow-500/25';
  if (chance >= 50) return 'bg-orange-500/15 text-orange-400 border-orange-500/25';
  if (chance >= 30) return 'bg-red-500/15 text-red-400 border-red-500/25';
  return 'bg-red-500/25 text-red-300 border-red-500/40';
}

const normalWALevels = Object.entries(normalScrollWeaponArmor).filter(([lv]) => Number(lv) > 3);
const normalJLevels = Object.entries(normalScrollJewelry).filter(([lv]) => Number(lv) > 3);
const blessedWALevels = Object.entries(blessedScrollWeaponArmor).filter(([lv]) => Number(lv) > 3);
const blessedJLevels = Object.entries(blessedScrollJewelry).filter(([lv]) => Number(lv) > 3);
const crystalWALevels = Object.entries(crystalScrollWeaponArmor);
const crystalJLevels = Object.entries(crystalScrollJewelry);

const scrollTypes = [
  {
    id: 'normal',
    icon: '📜',
    borderClass: 'border-red-500/30',
    titleClass: 'text-red-400',
    badgeClass: 'bg-red-500/15 text-red-400 border-red-500/30',
    failBgClass: 'bg-red-950/60 border-red-500/30 text-red-200',
    titleKey: 'info.enchantTab.normalScroll',
    title: 'Normal Scroll',
    range: '+4 ~ +16',
    rangeKey: 'info.enchantTab.normalScrollRange',
    failKey: 'info.enchantTab.normalScrollFail',
    failText: 'Fallo = item DESTRUIDO + cristales devueltos',
    failIcon: '💥',
    wa: normalWALevels,
    j: normalJLevels,
    waDescKey: 'info.enchantTab.normalScrollWADesc',
    waDesc: '80% base, -5% por nivel',
    jDescKey: 'info.enchantTab.normalScrollJDesc',
    jDesc: '90% base, -4% por nivel',
  },
  {
    id: 'blessed',
    icon: '✨',
    borderClass: 'border-blue-500/30',
    titleClass: 'text-blue-400',
    badgeClass: 'bg-blue-500/15 text-blue-400 border-blue-500/30',
    failBgClass: 'bg-blue-950/60 border-blue-500/30 text-blue-200',
    titleKey: 'info.enchantTab.blessedScroll',
    title: 'Blessed Scroll',
    range: '+4 ~ +16',
    rangeKey: 'info.enchantTab.blessedScrollRange',
    failKey: 'info.enchantTab.blessedScrollFail',
    failText: 'Fallo = item baja a +0',
    failIcon: '🔽',
    wa: blessedWALevels,
    j: blessedJLevels,
    waDescKey: 'info.enchantTab.blessedScrollWADesc',
    waDesc: '90% base, -3% por nivel',
    jDescKey: 'info.enchantTab.blessedScrollJDesc',
    jDesc: '85% base, -3% por nivel',
  },
  {
    id: 'crystal',
    icon: '💎',
    borderClass: 'border-green-500/30',
    titleClass: 'text-green-400',
    badgeClass: 'bg-green-500/15 text-green-400 border-green-500/30',
    failBgClass: 'bg-green-950/60 border-green-500/30 text-green-200',
    titleKey: 'info.enchantTab.crystalScroll',
    title: 'Crystal Scroll',
    range: '+17 ~ +25',
    rangeKey: 'info.enchantTab.crystalScrollRange',
    failKey: 'info.enchantTab.crystalScrollFail',
    failText: 'Fallo = no pasa nada, solo pierdes el scroll',
    failIcon: '🛡️',
    wa: crystalWALevels,
    j: crystalJLevels,
    waDescKey: 'info.enchantTab.crystalScrollWADesc',
    waDesc: '70% base, -5% por nivel',
    jDescKey: 'info.enchantTab.crystalScrollJDesc',
    jDesc: '65% base, -5% por nivel',
  },
];
---

<!-- General Info -->
<div class="grid sm:grid-cols-3 gap-4 mb-8">
  <div class="bg-linear-to-br from-slate-800/60 to-slate-900/60 p-5 rounded-xl border border-yellow-500/20 text-center group hover:border-yellow-500/40 transition-colors">
    <div class="inline-flex items-center justify-center w-10 h-10 rounded-lg bg-yellow-500/10 mb-3">
      <svg class="w-5 h-5 text-yellow-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
    </div>
    <p class="text-gray-400 text-xs uppercase tracking-wider mb-1" data-i18n="info.enchantTab.safeEnchant">Safe Enchant</p>
    <p class="text-yellow-400 font-bold text-3xl font-display">{enchantGeneral.safeEnchant}</p>
    <p class="text-gray-500 text-xs mt-1" data-i18n="info.enchantTab.safeEnchantDesc">+3 para todo (+4 para full body armor)</p>
  </div>
  <div class="bg-linear-to-br from-slate-800/60 to-slate-900/60 p-5 rounded-xl border border-yellow-500/20 text-center group hover:border-yellow-500/40 transition-colors">
    <div class="inline-flex items-center justify-center w-10 h-10 rounded-lg bg-yellow-500/10 mb-3">
      <svg class="w-5 h-5 text-yellow-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
    </div>
    <p class="text-gray-400 text-xs uppercase tracking-wider mb-1" data-i18n="info.enchantTab.maxEnchant">Enchant Maximo</p>
    <p class="text-yellow-400 font-bold text-3xl font-display">{enchantGeneral.maxEnchant}</p>
    <p class="text-gray-500 text-xs mt-1" data-i18n="info.enchantTab.maxEnchantDesc">+25 (armas, armaduras y joyas)</p>
  </div>
  <div class="bg-linear-to-br from-slate-800/60 to-slate-900/60 p-5 rounded-xl border border-yellow-500/20 text-center group hover:border-yellow-500/40 transition-colors">
    <div class="inline-flex items-center justify-center w-10 h-10 rounded-lg bg-yellow-500/10 mb-3">
      <svg class="w-5 h-5 text-yellow-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" /></svg>
    </div>
    <p class="text-gray-400 text-xs uppercase tracking-wider mb-1" data-i18n="info.enchantTab.soulCrystals">Soul Crystals</p>
    <p class="text-yellow-400 font-bold text-3xl font-display">{soulCrystals.levelUpChance}%</p>
    <p class="text-gray-500 text-xs mt-1">Lv. max {soulCrystals.maxLevel} · {soulCrystals.breakChance}% break</p>
  </div>
</div>

<!-- Scroll Types -->
<div class="space-y-6">
  {scrollTypes.map((scroll) => (
    <div class={`bg-linear-to-br from-slate-800/40 to-slate-900/60 rounded-xl border ${scroll.borderClass} overflow-hidden`}>
      <!-- Header -->
      <div class="p-5 pb-4">
        <div class="flex flex-col sm:flex-row sm:items-center gap-3 mb-3">
          <div class="flex items-center gap-3 flex-1">
            <span class="text-3xl">{scroll.icon}</span>
            <div>
              <h3 class={`text-xl font-bold ${scroll.titleClass} font-display`} data-i18n={scroll.titleKey}>{scroll.title}</h3>
              <span class={`text-xs font-mono font-bold px-2.5 py-0.5 rounded-full border ${scroll.badgeClass} inline-block mt-1`}>{scroll.range}</span>
            </div>
          </div>
        </div>
        <!-- Fail info - prominent -->
        <div class={`rounded-lg border px-4 py-3 flex items-center gap-3 ${scroll.failBgClass}`}>
          <span class="text-2xl shrink-0">{scroll.failIcon}</span>
          <p class="text-base font-bold tracking-wide" data-i18n={scroll.failKey}>{scroll.failText}</p>
        </div>
      </div>

      <!-- Chance grids -->
      <div class="grid md:grid-cols-2 gap-px bg-white/5">
        <!-- Weapon/Armor -->
        <div class="bg-slate-950/60 p-5">
          <div class="flex items-center gap-2.5 mb-4">
            <div class="flex items-center gap-2 flex-1 min-w-0">
              <svg class="w-5 h-5 text-orange-400 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 17.5L3 6V3h3l11.5 11.5"/><path d="M13 19l6-6"/><path d="M16 16l4 4"/><path d="M19 21l2-2"/></svg>
              <h4 class="text-sm font-bold text-white uppercase tracking-wider" data-i18n="info.enchantTab.weaponArmor">Armas y Armaduras</h4>
            </div>
            <span class="text-[11px] text-gray-400 font-semibold bg-white/5 px-2.5 py-1 rounded-md border border-white/10 whitespace-nowrap" data-i18n={scroll.waDescKey}>{scroll.waDesc}</span>
          </div>
          <div class="grid grid-cols-4 sm:grid-cols-5 lg:grid-cols-6 gap-1.5">
            {scroll.wa.map(([lv, chance]) => (
              <div class={`rounded-lg border px-2 py-2 text-center transition-transform hover:scale-105 ${getCellBg(chance as number)}`}>
                <div class="text-[10px] opacity-60 font-mono leading-none mb-0.5">+{lv}</div>
                <div class="text-sm font-bold font-mono leading-none">{chance}%</div>
              </div>
            ))}
          </div>
        </div>
        <!-- Jewelry -->
        <div class="bg-slate-950/60 p-5">
          <div class="flex items-center gap-2.5 mb-4">
            <div class="flex items-center gap-2 flex-1 min-w-0">
              <svg class="w-5 h-5 text-cyan-400 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 3h12l4 6-10 13L2 9z"/><path d="M2 9h20"/><path d="M12 22L8 9l4-6 4 6-4 13z"/></svg>
              <h4 class="text-sm font-bold text-white uppercase tracking-wider" data-i18n="info.enchantTab.jewelry">Joyas</h4>
            </div>
            <span class="text-[11px] text-gray-400 font-semibold bg-white/5 px-2.5 py-1 rounded-md border border-white/10 whitespace-nowrap" data-i18n={scroll.jDescKey}>{scroll.jDesc}</span>
          </div>
          <div class="grid grid-cols-4 sm:grid-cols-5 lg:grid-cols-6 gap-1.5">
            {scroll.j.map(([lv, chance]) => (
              <div class={`rounded-lg border px-2 py-2 text-center transition-transform hover:scale-105 ${getCellBg(chance as number)}`}>
                <div class="text-[10px] opacity-60 font-mono leading-none mb-0.5">+{lv}</div>
                <div class="text-sm font-bold font-mono leading-none">{chance}%</div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  ))}
</div>

<!-- Augmentation -->
<div class="bg-linear-to-br from-slate-800/40 to-slate-900/60 p-6 rounded-xl border border-purple-500/20 mt-8">
  <div class="flex items-center gap-3 mb-5">
    <div class="inline-flex items-center justify-center w-10 h-10 rounded-lg bg-purple-500/15">
      <svg class="w-5 h-5 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" /></svg>
    </div>
    <div>
      <h3 class="text-xl font-bold text-purple-400 font-display" data-i18n="info.enchantTab.augmentation">Augmentation (Life Stones)</h3>
      <p class="text-gray-500 text-xs" data-i18n="info.enchantTab.skillChance">Chance de skill</p>
    </div>
  </div>
  <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
    {augmentation.map((aug) => (
      <div class={`rounded-xl border p-4 text-center transition-transform hover:scale-105 ${getCellBg(aug.chance)}`}>
        <p class="text-xs uppercase tracking-wider opacity-70 mb-1 font-semibold" data-i18n={`info.enchantTab.${aug.key}`}>{aug.key}</p>
        <p class="text-2xl font-bold font-mono">{aug.chance}%</p>
      </div>
    ))}
  </div>
</div>
