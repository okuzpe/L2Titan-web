---
interface Props {
  href: string;
  variant?: 'primary' | 'ghost' | 'discord';
  target?: '_blank' | '_self';
  rel?: string;
  download?: string;
  className?: string;
}

const {
  href,
  variant = 'primary',
  target,
  rel,
  download,
  className = '',
} = Astro.props;

const variantClass =
  variant === 'discord' ? 'df-btn-discord' : variant === 'ghost' ? 'df-btn-ghost' : 'df-btn-primary';
---

<a href={href} target={target} rel={rel} download={download} class={`${variantClass} ${className}`.trim()}>
  <slot />
</a>
