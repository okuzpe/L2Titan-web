          <div class="relative">
            <button id="language-toggle" class="text-gray-300 hover:text-white hover:bg-white/10 px-3 py-2 rounded-md text-sm font-medium transition-all flex items-center gap-2" aria-label="Change language">
              <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
