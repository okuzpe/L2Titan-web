---
---
<nav class="df-surface-strong rounded-none border-x-0 sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <div class="flex items-center">
        <a href="/" class="text-3xl font-bold text-yellow-500 tracking-widest hover:text-yellow-400 transition-colors font-display" style="text-shadow: 0 0 10px rgba(255, 215, 0, 0.5);">
          L2TITAN
        </a>
      </div>
      <!-- Desktop nav -->
      <div class="hidden md:block">
        <div class="ml-10 flex items-baseline space-x-4">
          <a href="/" class="text-gray-300 hover:text-white hover:bg-white/10 px-3 py-2 rounded-lg text-sm font-medium transition-all" data-i18n="navbar.home">Home</a>
          <a href="/downloads" class="text-gray-300 hover:text-white hover:bg-white/10 px-3 py-2 rounded-lg text-sm font-medium transition-all" data-i18n="navbar.downloads">Downloads</a>
          <a href="/rates" class="text-gray-300 hover:text-white hover:bg-white/10 px-3 py-2 rounded-lg text-sm font-medium transition-all" data-i18n="navbar.info">Info</a>
          <a href="#vote-section" class="text-gray-300 hover:text-white hover:bg-white/10 px-3 py-2 rounded-lg text-sm font-medium transition-all" data-i18n="navbar.vote">Vote</a>
          <a href="/#social-media" class="text-gray-300 hover:text-white hover:bg-white/10 px-3 py-2 rounded-lg text-sm font-medium transition-all" data-i18n="navbar.socialMedia">Social Media</a>
          <div class="relative">
            <button id="language-toggle" class="text-gray-300 hover:text-white hover:bg-white/10 px-3 py-2 rounded-lg text-sm font-medium transition-all flex items-center gap-2" aria-label="Change language">
              <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129"/>
              </svg>
              <span id="current-language" class="uppercase">EN</span>
            </button>
          </div>
          <div class="flex items-center gap-3 px-3 py-2 rounded-md border border-white/5 bg-white/5">
            <div class="flex items-center gap-1.5">
              <span id="status-game-dot" class="inline-block w-2 h-2 rounded-full bg-gray-500 transition-colors"></span>
              <span class="text-xs text-gray-400 uppercase tracking-wider" data-i18n="status.game">Game</span>
            </div>
            <div class="flex items-center gap-1.5">
              <span id="status-login-dot" class="inline-block w-2 h-2 rounded-full bg-gray-500 transition-colors"></span>
              <span class="text-xs text-gray-400 uppercase tracking-wider" data-i18n="status.login">Login</span>
            </div>
          </div>
        </div>
      </div>
      <!-- Mobile hamburger button -->
      <button id="mobile-menu-btn" class="md:hidden text-gray-300 hover:text-white p-2 rounded-lg transition-colors" aria-label="Toggle menu" aria-expanded="false">
        <svg id="hamburger-icon" class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
        <svg id="close-icon" class="h-6 w-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
  </div>
  <!-- Mobile menu panel -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-white/10">
    <div class="px-4 py-3 space-y-1">
      <a href="/" class="mobile-nav-link block text-gray-300 hover:text-white hover:bg-white/10 px-3 py-3 rounded-lg text-base font-medium transition-all" data-i18n="navbar.home">Home</a>
      <a href="/downloads" class="mobile-nav-link block text-gray-300 hover:text-white hover:bg-white/10 px-3 py-3 rounded-lg text-base font-medium transition-all" data-i18n="navbar.downloads">Downloads</a>
      <a href="/rates" class="mobile-nav-link block text-gray-300 hover:text-white hover:bg-white/10 px-3 py-3 rounded-lg text-base font-medium transition-all" data-i18n="navbar.info">Info</a>
      <a href="#vote-section" class="mobile-nav-link block text-gray-300 hover:text-white hover:bg-white/10 px-3 py-3 rounded-lg text-base font-medium transition-all" data-i18n="navbar.vote">Vote</a>
      <a href="/#social-media" class="mobile-nav-link block text-gray-300 hover:text-white hover:bg-white/10 px-3 py-3 rounded-lg text-base font-medium transition-all" data-i18n="navbar.socialMedia">Social Media</a>
      <div class="flex items-center justify-between px-3 py-3 border-t border-white/10 mt-2 pt-3">
        <button id="language-toggle-mobile" class="text-gray-300 hover:text-white hover:bg-white/10 px-3 py-2 rounded-md text-sm font-medium transition-all flex items-center gap-2" aria-label="Change language">
          <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129"/>
          </svg>
          <span id="current-language-mobile" class="uppercase">EN</span>
        </button>
        <div class="flex items-center gap-3 px-3 py-2 rounded-md border border-white/5 bg-white/5">
          <div class="flex items-center gap-1.5">
            <span id="status-game-dot-mobile" class="inline-block w-2 h-2 rounded-full bg-gray-500 transition-colors"></span>
            <span class="text-xs text-gray-400 uppercase tracking-wider" data-i18n="status.game">Game</span>
          </div>
          <div class="flex items-center gap-1.5">
            <span id="status-login-dot-mobile" class="inline-block w-2 h-2 rounded-full bg-gray-500 transition-colors"></span>
            <span class="text-xs text-gray-400 uppercase tracking-wider" data-i18n="status.login">Login</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</nav>

<style>
  @keyframes status-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }
  .status-online {
    background-color: #4ade80;
    box-shadow: 0 0 6px rgba(74, 222, 128, 0.6);
    animation: status-pulse 2s ease-in-out infinite;
  }
  .status-offline {
    background-color: #f87171;
    box-shadow: 0 0 6px rgba(248, 113, 113, 0.6);
  }
</style>

<script is:inline>
  (function() {
    function initMobileMenu() {
      var btn = document.getElementById('mobile-menu-btn');
      var menu = document.getElementById('mobile-menu');
      var hamburgerIcon = document.getElementById('hamburger-icon');
      var closeIcon = document.getElementById('close-icon');
      if (!btn || !menu || !hamburgerIcon || !closeIcon) return;

      btn.addEventListener('click', function() {
        var isOpen = !menu.classList.contains('hidden');
        menu.classList.toggle('hidden');
        hamburgerIcon.classList.toggle('hidden');
        closeIcon.classList.toggle('hidden');
        btn.setAttribute('aria-expanded', String(!isOpen));
      });

      var mobileLinks = menu.querySelectorAll('.mobile-nav-link');
      mobileLinks.forEach(function(link) {
        link.addEventListener('click', function() {
          menu.classList.add('hidden');
          hamburgerIcon.classList.remove('hidden');
          closeIcon.classList.add('hidden');
          btn.setAttribute('aria-expanded', 'false');
        });
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initMobileMenu);
    } else {
      initMobileMenu();
    }
  })();
</script>

<script is:inline>
  (function() {
    var dotBase = 'inline-block w-2 h-2 rounded-full transition-colors ';

    function applyStatus(id, statusClass) {
      var el = document.getElementById(id);
      if (el) el.className = dotBase + statusClass;
    }

    function fetchServerStatus() {
      var gameDot = document.getElementById('status-game-dot');
      var loginDot = document.getElementById('status-login-dot');
      if (!gameDot || !loginDot) return;

      fetch('/status')
        .then(function(res) { return res.json(); })
        .then(function(data) {
          var gameClass = data.game === 'online' ? 'status-online' : 'status-offline';
          var loginClass = data.login === 'online' ? 'status-online' : 'status-offline';
          applyStatus('status-game-dot', gameClass);
          applyStatus('status-game-dot-mobile', gameClass);
          applyStatus('status-login-dot', loginClass);
          applyStatus('status-login-dot-mobile', loginClass);
        })
        .catch(function() {
          var fallback = 'bg-gray-500';
          applyStatus('status-game-dot', fallback);
          applyStatus('status-game-dot-mobile', fallback);
          applyStatus('status-login-dot', fallback);
          applyStatus('status-login-dot-mobile', fallback);
        });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', fetchServerStatus);
    } else {
      fetchServerStatus();
    }
    setInterval(fetchServerStatus, 60000);
  })();
</script>

<script is:inline>
  (function() {
    function initLanguageToggle() {
      if (!window.i18n) return;

      var langElements = ['current-language', 'current-language-mobile'];
      var currentLang = window.i18n.getLanguage();
      langElements.forEach(function(id) {
        var el = document.getElementById(id);
        if (el) el.textContent = currentLang.toUpperCase();
      });

      function toggleLanguage() {
        var current = window.i18n.getLanguage();
        var newLang = current === 'es' ? 'en' : 'es';
        window.i18n.setLanguage(newLang);
      }

      var toggleDesktop = document.getElementById('language-toggle');
      var toggleMobile = document.getElementById('language-toggle-mobile');
      if (toggleDesktop) toggleDesktop.addEventListener('click', toggleLanguage);
      if (toggleMobile) toggleMobile.addEventListener('click', toggleLanguage);

      window.addEventListener('languagechange', function() {
        if (!window.i18n) return;
        var lang = window.i18n.getLanguage().toUpperCase();
        langElements.forEach(function(id) {
          var el = document.getElementById(id);
          if (el) el.textContent = lang;
        });
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initLanguageToggle);
    } else {
      initLanguageToggle();
    }
  })();
</script>
