---
import Layout from '../layouts/Layout.astro';
import ActionButton from '../components/ui/ActionButton.astro';
import CardSurface from '../components/ui/CardSurface.astro';
import SectionHeading from '../components/ui/SectionHeading.astro';

const downloads = [
  { 
    name: 'Cliente Completo', 
    nameKey: 'downloads.fileNames.fullClient',
    size: '2.8 GB', 
    link: 'https://drive.google.com/file/d/12kuIp38V9BqX4MfRVMA_Kq7S5_MCIAp0/view?usp=sharing', 
    type: 'Google Drive',
    icon: { 
      class: 'w-6 h-6 text-yellow-500', 
      path: 'M7.71 3.5L1.15 15l3.42 5.91L12 15l-4.29-7.5L7.71 3.5M12 15l3.42 5.91L22.85 15l-3.42-5.91L12 15m0 0L8.58 9.09 12 3.5l3.42 5.59L12 15z',
      fill: true
    }
  },
  { 
    name: 'Cliente Completo', 
    nameKey: 'downloads.fileNames.fullClient',
    size: '2.8 GB', 
    link: 'https://mega.nz/file/ANUhyLCa#WZGTUG1Vepl7raHnNNzYZE12oUZf_oAp0XWRB1uMVpk', 
    type: 'Mega',
    icon: { 
      class: 'w-6 h-6 text-yellow-500', 
      path: 'M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm6.895 8.104l-6.895 6.895-6.895-6.895L12 5.21l6.895 2.894z',
      fill: true
    }
  },
  { 
    name: 'Cliente Completo', 
    nameKey: 'downloads.fileNames.fullClient',
    size: '2.8 GB', 
    link: 'https://downloads.l2-titan.com/zip/Lineage2.zip', 
    type: 'Direct', 
    filename: 'Lineage2.zip',
    icon: { 
      class: 'w-6 h-6 text-yellow-500', 
      path: 'M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4',
      fill: false
    }
  },
  { 
    name: 'Launcher', 
    nameKey: 'downloads.fileNames.launcher',
    size: '74 MB', 
    link: 'https://downloads.l2-titan.com/zip/L2TitanLauncher.zip', 
    type: 'Direct', 
    filename: 'L2TitanLauncher.exe',
    icon: { 
      class: 'w-6 h-6 text-yellow-500', 
      path: 'M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4',
      fill: false
    }
  },
];

// Función helper para determinar si es un enlace directo
const isDirectDownload = (type: string) => type === 'Direct';

const softwareAppLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "L2Titan - Lineage 2 Interlude Client",
  "operatingSystem": "Windows 7, Windows 8, Windows 10, Windows 11",
  "applicationCategory": "GameApplication",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  },
  "fileSize": "2.8 GB",
  "downloadUrl": "https://downloads.l2-titan.com/zip/Lineage2.zip",
  "description": "Cliente completo de L2Titan - Servidor Privado de Lineage 2 Interlude x25 con subclases acumulativas, TvT activo y PvP intenso."
};

// Función helper para obtener el nombre del archivo
const getDownloadFilename = (file: typeof downloads[0]) => {
  if (file.filename) return file.filename;
  const url = new URL(file.link);
  const pathname = url.pathname;
  const filename = pathname.split('/').pop() || '';
  return filename || `${file.name.replace(/\s+/g, '')}.${file.link.match(/\.(\w+)$/)?.[1] || 'exe'}`;
};

---

<Layout
	title="Descargar Cliente"
	description="Descarga el cliente de L2Titan - Lineage 2 Interlude x25 gratis. Cliente completo, launcher y requisitos del sistema. Disponible en Google Drive, Mega y descarga directa."
	keywords="descargar lineage 2, download lineage 2, l2 interlude download, lineage 2 client download, descargar l2 interlude, l2 titan download, lineage 2 free download, l2 client gratis, descargar cliente lineage 2, lineage 2 interlude client, l2 launcher download"
>
  <script type="application/ld+json" set:html={JSON.stringify(softwareAppLd)} />
  <div class="container mx-auto px-4 py-12 md:py-24">
    <SectionHeading text="CENTRO DE DESCARGAS" i18nKey="downloads.title" className="mb-8 md:mb-12" />

    <CardSurface className="max-w-5xl mx-auto mb-8 md:mb-10 bg-emerald-500/10 border-emerald-400/30 p-5 md:p-6">
      <div class="flex items-start gap-3">
        <span class="text-2xl leading-none">✅</span>
        <div>
          <h2 class="text-emerald-300 font-bold text-lg md:text-xl mb-1" data-i18n="downloads.accountNotice.title">
            Auto Create Account activado
          </h2>
          <p class="text-emerald-100/90 text-sm md:text-base" data-i18n="downloads.accountNotice.description">
            No necesitas registrarte en una web. Tu cuenta se crea automaticamente cuando entras al juego por primera vez.
          </p>
        </div>
      </div>
    </CardSurface>
    
    <!-- Desktop table -->
    <div class="hidden md:block max-w-5xl mx-auto bg-slate-900/80 backdrop-blur-md rounded-xl border border-yellow-500/20 overflow-hidden mb-16 shadow-[0_0_30px_rgba(0,0,0,0.5)]">
      <div class="overflow-x-auto">
        <table class="w-full text-left">
          <thead class="bg-linear-to-r from-slate-900 via-slate-800 to-slate-900 text-yellow-500 uppercase text-sm font-display tracking-wider border-b border-yellow-500/20">
            <tr>
              <th class="px-8 py-6 font-bold" data-i18n="downloads.table.file">Archivo</th>
              <th class="px-8 py-6 font-bold" data-i18n="downloads.table.size">Tamaño</th>
              <th class="px-8 py-6 font-bold" data-i18n="downloads.table.type">Tipo</th>
              <th class="px-8 py-6 font-bold text-right" data-i18n="downloads.table.action">Acción</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-white/5">
            {downloads.map((file) => (
              <tr class="hover:bg-yellow-500/5 transition-colors group">
                <td class="px-8 py-6 font-medium text-white group-hover:text-yellow-200 transition-colors flex items-center gap-3">
                  {file.icon.fill ? (
                    <svg class={file.icon.class} fill="currentColor" viewBox="0 0 24 24">
                      <path d={file.icon.path} />
                    </svg>
                  ) : (
                    <svg class={file.icon.class} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={file.icon.path} />
                    </svg>
                  )}
                  {file.nameKey ? <span data-i18n={file.nameKey}>{file.name}</span> : file.name}
                </td>
                <td class="px-8 py-6 text-gray-400 font-mono">{file.size}</td>
                <td class="px-8 py-6 text-gray-400">{file.type}</td>
                <td class="px-8 py-6 text-right">
                  <ActionButton 
                    href={file.link} 
                    download={isDirectDownload(file.type) ? getDownloadFilename(file) : undefined}
                    target={file.link !== '#' ? '_blank' : undefined} 
                    rel={file.link !== '#' ? 'noopener noreferrer' : undefined}
                    variant="ghost"
                    className="px-6 py-2 text-sm"
                  >
                    <span data-i18n="downloads.download">Descargar</span>
                  </ActionButton>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <!-- Mobile cards -->
    <div class="md:hidden max-w-5xl mx-auto space-y-4 mb-12">
      {downloads.map((file) => (
        <CardSurface variant="strong" className="p-5 shadow-[0_0_30px_rgba(0,0,0,0.5)]">
          <div class="flex items-center gap-3 mb-3">
            {file.icon.fill ? (
              <svg class={file.icon.class} fill="currentColor" viewBox="0 0 24 24">
                <path d={file.icon.path} />
              </svg>
            ) : (
              <svg class={file.icon.class} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={file.icon.path} />
              </svg>
            )}
            <span class="font-medium text-white">
              {file.nameKey ? <span data-i18n={file.nameKey}>{file.name}</span> : file.name}
            </span>
          </div>
          <div class="flex items-center gap-3 mb-4">
            <span class="text-gray-400 font-mono text-sm">{file.size}</span>
            <span class="text-xs text-gray-500 bg-white/5 px-2 py-0.5 rounded">{file.type}</span>
          </div>
          <ActionButton 
            href={file.link} 
            download={isDirectDownload(file.type) ? getDownloadFilename(file) : undefined}
            target={file.link !== '#' ? '_blank' : undefined} 
            rel={file.link !== '#' ? 'noopener noreferrer' : undefined}
            variant="ghost"
            className="w-full px-6 py-3"
          >
            <span data-i18n="downloads.download">Descargar</span>
          </ActionButton>
        </CardSurface>
      ))}
    </div>

    <div class="max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-8">
      <CardSurface className="p-5 md:p-8 hover:border-yellow-500/30 transition-colors">
        <h2 class="text-xl md:text-2xl font-bold text-white mb-4 md:mb-6 font-display flex items-center gap-2">
          <span class="text-yellow-500" data-i18n="downloads.requirements.minimum">MINIMOS</span> <span data-i18n="downloads.requirements.requirements">REQUISITOS</span>
        </h2>
        <ul class="space-y-2 md:space-y-3 text-gray-400 text-sm">
          <li class="flex justify-between border-b border-white/5 pb-2"><span>OS:</span> <span class="text-gray-200">Windows 7/8/10</span></li>
          <li class="flex justify-between border-b border-white/5 pb-2"><span>CPU:</span> <span class="text-gray-200">Intel Core i3</span></li>
          <li class="flex justify-between border-b border-white/5 pb-2"><span>RAM:</span> <span class="text-gray-200">4 GB</span></li>
          <li class="flex justify-between border-b border-white/5 pb-2"><span>GPU:</span> <span class="text-gray-200">GeForce GT 630</span></li>
          <li class="flex justify-between pt-2"><span>HDD:</span> <span class="text-gray-200">30 GB libres</span></li>
        </ul>
      </CardSurface>
      <CardSurface className="p-5 md:p-8 hover:border-yellow-500/30 transition-colors">
        <h2 class="text-xl md:text-2xl font-bold text-white mb-4 md:mb-6 font-display flex items-center gap-2">
          <span class="text-yellow-500" data-i18n="downloads.requirements.recommended">RECOMENDADOS</span> <span data-i18n="downloads.requirements.requirements">REQUISITOS</span>
        </h2>
        <ul class="space-y-2 md:space-y-3 text-gray-400 text-sm">
          <li class="flex justify-between border-b border-white/5 pb-2"><span>OS:</span> <span class="text-gray-200">Windows 10/11</span></li>
          <li class="flex justify-between border-b border-white/5 pb-2"><span>CPU:</span> <span class="text-gray-200">Intel Core i5+</span></li>
          <li class="flex justify-between border-b border-white/5 pb-2"><span>RAM:</span> <span class="text-gray-200">8 GB+</span></li>
          <li class="flex justify-between border-b border-white/5 pb-2"><span>GPU:</span> <span class="text-gray-200">GeForce GTX 1050+</span></li>
          <li class="flex justify-between pt-2"><span>HDD:</span> <span class="text-gray-200">SSD 30 GB</span></li>
        </ul>
      </CardSurface>
    </div>

    <CardSurface className="max-w-5xl mx-auto mt-8 md:mt-10 p-5 md:p-8 hover:border-yellow-500/30 transition-colors">
      <h2 class="text-xl md:text-2xl font-bold text-yellow-400 mb-4 font-display" data-i18n="downloads.quickStart.title">
        Pasos rapidos para jugar
      </h2>
      <ol class="space-y-2 md:space-y-3 text-gray-300 text-sm md:text-base list-decimal pl-5">
        <li data-i18n="downloads.quickStart.step1">Descarga el Cliente Completo o el Launcher.</li>
        <li data-i18n="downloads.quickStart.step2">Descomprime el juego y abre L2TitanLauncher.</li>
        <li data-i18n="downloads.quickStart.step3">Inicia sesion en el juego con el usuario y clave que quieras.</li>
        <li data-i18n="downloads.quickStart.step4">Tu cuenta se crea automaticamente al primer login (Auto Create Account).</li>
      </ol>
    </CardSurface>
  </div>
</Layout>
