---
import Layout from '../layouts/Layout.astro';

const downloads = [
  { name: 'Cliente Completo', size: '12 GB', link: '#', type: 'Torrent' },
  { name: 'Cliente Completo', size: '12 GB', link: '#', type: 'Google Drive' },
  { name: 'Cliente Completo', size: '12 GB', link: '#', type: 'Mega' },
  { name: 'System Patch', size: '150 MB', link: '#', type: 'Direct' },
  { name: 'Updater', size: '5 MB', link: '#', type: 'Direct' },
];
---

<Layout title="Descargas">
  <div class="container mx-auto px-4 py-24">
    <h1 class="text-5xl font-bold text-transparent bg-clip-text bg-gradient-to-b from-yellow-300 to-yellow-600 mb-12 text-center font-display tracking-widest drop-shadow-lg">CENTRO DE DESCARGAS</h1>
    
    <div class="max-w-5xl mx-auto bg-slate-900/80 backdrop-blur-md rounded-xl border border-yellow-500/20 overflow-hidden mb-16 shadow-[0_0_30px_rgba(0,0,0,0.5)]">
      <div class="overflow-x-auto">
        <table class="w-full text-left">
          <thead class="bg-gradient-to-r from-slate-900 via-slate-800 to-slate-900 text-yellow-500 uppercase text-sm font-display tracking-wider border-b border-yellow-500/20">
            <tr>
              <th class="px-8 py-6 font-bold">Archivo</th>
              <th class="px-8 py-6 font-bold">Tamaño</th>
              <th class="px-8 py-6 font-bold">Tipo</th>
              <th class="px-8 py-6 font-bold text-right">Acción</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-white/5">
            {downloads.map((file) => (
              <tr class="hover:bg-yellow-500/5 transition-colors group">
                <td class="px-8 py-6 font-medium text-white group-hover:text-yellow-200 transition-colors flex items-center gap-3">
                  <svg class="w-5 h-5 text-yellow-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                  {file.name}
                </td>
                <td class="px-8 py-6 text-gray-400 font-mono">{file.size}</td>
                <td class="px-8 py-6 text-gray-400">{file.type}</td>
                <td class="px-8 py-6 text-right">
                  <a href={file.link} class="inline-block px-6 py-2 bg-yellow-600/20 hover:bg-yellow-500 text-yellow-500 hover:text-black border border-yellow-500/50 hover:border-yellow-500 text-sm font-bold rounded transition-all uppercase tracking-wider">
                    Descargar
                  </a>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <div class="max-w-5xl mx-auto grid md:grid-cols-2 gap-8">
      <div class="bg-slate-900/50 p-8 rounded-xl border border-white/10 hover:border-yellow-500/30 transition-colors">
        <h3 class="text-2xl font-bold text-white mb-6 font-display flex items-center gap-2">
          <span class="text-yellow-500">MINIMOS</span> REQUISITOS
        </h3>
        <ul class="space-y-3 text-gray-400 text-sm">
          <li class="flex justify-between border-b border-white/5 pb-2"><span>OS:</span> <span class="text-gray-200">Windows 7/8/10</span></li>
          <li class="flex justify-between border-b border-white/5 pb-2"><span>CPU:</span> <span class="text-gray-200">Intel Core i3</span></li>
          <li class="flex justify-between border-b border-white/5 pb-2"><span>RAM:</span> <span class="text-gray-200">4 GB</span></li>
          <li class="flex justify-between border-b border-white/5 pb-2"><span>GPU:</span> <span class="text-gray-200">GeForce GT 630</span></li>
          <li class="flex justify-between pt-2"><span>HDD:</span> <span class="text-gray-200">30 GB libres</span></li>
        </ul>
      </div>
      <div class="bg-slate-900/50 p-8 rounded-xl border border-white/10 hover:border-yellow-500/30 transition-colors">
        <h3 class="text-2xl font-bold text-white mb-6 font-display flex items-center gap-2">
          <span class="text-yellow-500">RECOMENDADOS</span> REQUISITOS
        </h3>
        <ul class="space-y-3 text-gray-400 text-sm">
          <li class="flex justify-between border-b border-white/5 pb-2"><span>OS:</span> <span class="text-gray-200">Windows 10/11</span></li>
          <li class="flex justify-between border-b border-white/5 pb-2"><span>CPU:</span> <span class="text-gray-200">Intel Core i5+</span></li>
          <li class="flex justify-between border-b border-white/5 pb-2"><span>RAM:</span> <span class="text-gray-200">8 GB+</span></li>
          <li class="flex justify-between border-b border-white/5 pb-2"><span>GPU:</span> <span class="text-gray-200">GeForce GTX 1050+</span></li>
          <li class="flex justify-between pt-2"><span>HDD:</span> <span class="text-gray-200">SSD 30 GB</span></li>
        </ul>
      </div>
    </div>
  </div>
</Layout>
