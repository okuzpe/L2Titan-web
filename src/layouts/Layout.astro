---
import "../styles/global.css";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import { translations } from "../data/translations";

interface Props {
	title: string;
}

const { title } = Astro.props;

// Convert translations to JSON string for inline script
const translationsJson = JSON.stringify(translations);

// Detect initial language for HTML lang attribute (server-side)
// Default to Spanish for better SEO in target market
const defaultLang = 'es';
---

<!doctype html>
<html lang={defaultLang} class="dark">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="L2Titan - Interlude Private Server" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700;900&family=Inter:wght@300;400;600&display=swap"
			rel="stylesheet"
		/>
		<meta name="generator" content={Astro.generator} />
		<title>{title} | L2Titan</title>
		<style is:inline>
			body {
				opacity: 0;
				transition: opacity 0.1s ease-in;
			}
			body.i18n-ready,
			body.no-js {
				opacity: 1;
			}
		</style>
		<script is:inline define:vars={{ translationsJson }}>
			(function() {
				// Execute immediately before body renders
				const translationsData = JSON.parse(translationsJson);

				// Make functions globally available
				window.i18n = {
					getLanguage: function() {
						if (typeof localStorage === 'undefined') return 'en';
						const saved = localStorage.getItem('language');
						if (saved === 'es' || saved === 'en') return saved;
						// Detect browser language as default
						if (typeof navigator !== 'undefined' && navigator.language) {
							const browserLang = navigator.language.split('-')[0];
							return browserLang === 'es' ? 'es' : 'en';
						}
						return 'en';
					},
					getTranslation: function(key, lang) {
						const currentLang = lang || window.i18n.getLanguage();
						const keys = key.split('.');
						let value = translationsData[currentLang];
						
						for (const k of keys) {
							value = value?.[k];
							if (value === undefined) {
								console.warn('Translation key not found: ' + key);
								return key;
							}
						}
						
						return typeof value === 'string' ? value : key;
					},
					updateTranslations: function() {
						const lang = window.i18n.getLanguage();
						document.documentElement.lang = lang;
						const elements = document.querySelectorAll('[data-i18n]');
						
						elements.forEach((element) => {
							const key = element.getAttribute('data-i18n');
							if (key) {
								const translation = window.i18n.getTranslation(key, lang);
								if (element.tagName === 'INPUT' || element.tagName === 'TEXTAREA') {
									element.placeholder = translation;
								} else {
									element.textContent = translation;
								}
							}
						});

						// Update title attributes
						const titleElements = document.querySelectorAll('[data-i18n-title]');
						titleElements.forEach((element) => {
							const key = element.getAttribute('data-i18n-title');
							if (key) {
								element.setAttribute('title', window.i18n.getTranslation(key, lang));
							}
						});

						// Update alt attributes
						const altElements = document.querySelectorAll('[data-i18n-alt]');
						altElements.forEach((element) => {
							const key = element.getAttribute('data-i18n-alt');
							if (key) {
								element.alt = window.i18n.getTranslation(key, lang);
							}
						});

						// Update language indicator in navbar
						const langIndicator = document.getElementById('current-language');
						if (langIndicator) {
							langIndicator.textContent = lang.toUpperCase();
						}

						// Show body once translations are applied
						if (document.body) {
							document.body.classList.add('i18n-ready');
						}
					},
					setLanguage: function(lang) {
						if (typeof localStorage !== 'undefined') {
							localStorage.setItem('language', lang);
						}
						window.i18n.updateTranslations();
						// Dispatch custom event for other components
						window.dispatchEvent(new CustomEvent('languagechange', { detail: { language: lang } }));
					}
				};

				// Set initial language attribute immediately if document is available
				if (typeof document !== 'undefined' && document.documentElement) {
					const initialLang = window.i18n.getLanguage();
					document.documentElement.lang = initialLang;
				}
			})();
		</script>
	</head>
	<body
		class="min-h-screen flex flex-col bg-black text-slate-200 overflow-x-hidden"
	>
		<Navbar />
		<main class="flex-grow">
			<slot />
		</main>
		<Footer />
		<noscript>
			<style>
				body { opacity: 1 !important; }
			</style>
		</noscript>
		<script is:inline>
			// Apply translations synchronously immediately when body is parsed (before paint)
			(function() {
				if (window.i18n && typeof window.i18n.updateTranslations === 'function') {
					// Ensure html lang attribute is set based on detected language
					const lang = window.i18n.getLanguage();
					if (document.documentElement) {
						document.documentElement.lang = lang;
					}
					// Apply translations immediately - this executes synchronously before browser paints
					window.i18n.updateTranslations();
					// Ensure body is visible
					if (document.body) {
						document.body.classList.add('i18n-ready');
					}
				} else {
					// Fallback: show content if i18n system fails to initialize
					if (document.body) {
						document.body.classList.add('no-js');
					}
				}
			})();
		</script>
	</body>
</html>