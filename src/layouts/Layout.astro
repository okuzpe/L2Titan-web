---
import "../styles/global.css";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import { translations } from "../data/translations";

interface Props {
	title: string;
	description?: string;
	keywords?: string;
	ogImage?: string;
	ogType?: string;
	articlePublishedTime?: string;
	noindex?: boolean;
}

const {
	title,
	description = "L2Titan Interlude x25 sobre base L2JFrozen con SubStack, AutoFarm configurable, TvT activo, instancias diarias y comandos in-game para progresar con claridad.",
	keywords = "lineage 2 private server x25, l2 interlude private server, l2 titan, l2 substack, lineage 2 cumulative subclasses, l2 interlude pvp server, l2 events tvt, l2 daily instances, l2 ranking .top",
	ogImage = "/images/background.jpg",
	ogType = "website",
	articlePublishedTime,
	noindex = false,
} = Astro.props;

// Convert translations to JSON string for inline script
const translationsJson = JSON.stringify(translations);

// Detect initial language for HTML lang attribute (server-side)
// Default to Spanish for better SEO in target market
const defaultLang = 'es';

// Build canonical URL
const canonicalURL = new URL(Astro.url.pathname, Astro.site || 'https://l2-titan.com');

// Build full OG image URL
const ogImageURL = new URL(ogImage, Astro.site || 'https://l2-titan.com').toString();

// Full title
const siteTitle = "L2Titan 30x - Lineage 2 Interlude Private Server SubStack";
const fullTitle = title === "Inicio" ? siteTitle : `${title} | ${siteTitle}`;

// JSON-LD Structured Data
const jsonLd = {
	"@context": "https://schema.org",
	"@type": "WebSite",
	"name": "L2Titan",
	"alternateName": ["L2 Titan", "Lineage 2 Titan", "L2Titan 30x", "L2Titan SubStack"],
	"url": "https://l2-titan.com",
	"description": "Servidor privado de Lineage 2 Interlude x25 con SubStack, TvT activo, instancias diarias y comandos in-game claros.",
	"inLanguage": ["es", "en"]
};

const organizationLd = {
	"@context": "https://schema.org",
	"@type": "Organization",
	"name": "L2Titan",
	"alternateName": ["L2 Titan", "L2Titan 30x", "L2Titan SubStack"],
	"url": "https://l2-titan.com",
	"logo": "https://l2-titan.com/favicon.svg",
	"sameAs": [
		"https://discord.gg/GunamUdGaQ"
	],
	"description": "L2Titan - Servidor privado de Lineage 2 Interlude x25 con SubStack, TvT activo y comunidad PvP activa."
};

const gameServerLd = {
	"@context": "https://schema.org",
	"@type": "VideoGame",
	"name": "L2Titan 30x - Lineage 2 Interlude SubStack",
	"alternateName": ["L2Titan", "L2 Titan 30x", "L2Titan SubStack"],
	"description": "Servidor privado de Lineage 2 Interlude con rates x25, SubStack, TvT activo, instancias diarias y sistema VIP.",
	"gamePlatform": "PC",
	"applicationCategory": "Game",
	"operatingSystem": "Windows",
	"offers": {
		"@type": "Offer",
		"price": "0",
		"priceCurrency": "USD",
		"availability": "https://schema.org/InStock"
	},
	"genre": ["MMORPG", "PvP", "Fantasy"],
	"url": "https://l2-titan.com"
};

const siteBase = Astro.site?.toString().replace(/\/$/, '') || 'https://l2-titan.com';
const pathSegments = Astro.url.pathname.split('/').filter(Boolean);
const breadcrumbItems = [
	{ "@type": "ListItem", "position": 1, "name": "Inicio", "item": siteBase }
];
if (pathSegments.length > 0) {
	let currentPath = '';
	pathSegments.forEach((segment, i) => {
		currentPath += `/${segment}`;
		breadcrumbItems.push({
			"@type": "ListItem",
			"position": i + 2,
			"name": title,
			"item": `${siteBase}${currentPath}`
		});
	});
}
const breadcrumbLd = {
	"@context": "https://schema.org",
	"@type": "BreadcrumbList",
	"itemListElement": breadcrumbItems
};
---

<!doctype html>
<html lang={defaultLang} class="dark">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />

		<!-- Primary SEO Meta Tags -->
		<title>{fullTitle}</title>
		<meta name="description" content={description} />
		<meta name="keywords" content={keywords} />
		<meta name="author" content="L2Titan" />
		<meta name="robots" content={noindex ? "noindex, nofollow" : "index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"} />
		<link rel="canonical" href={canonicalURL.toString()} />

		<!-- Hreflang for multilingual SEO -->
		<link rel="alternate" hreflang="es" href={canonicalURL.toString()} />
		<link rel="alternate" hreflang="en" href={canonicalURL.toString()} />
		<link rel="alternate" hreflang="x-default" href={canonicalURL.toString()} />

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content={ogType} />
		<meta property="og:url" content={canonicalURL.toString()} />
		<meta property="og:title" content={fullTitle} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={ogImageURL} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:site_name" content="L2Titan" />
		<meta property="og:locale" content="es_ES" />
		<meta property="og:locale:alternate" content="en_US" />
		{articlePublishedTime && <meta property="article:published_time" content={articlePublishedTime} />}

		<!-- Twitter Card -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:url" content={canonicalURL.toString()} />
		<meta name="twitter:title" content={fullTitle} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImageURL} />

		<!-- Additional SEO Meta -->
		<meta name="theme-color" content="#000000" />
		<meta name="application-name" content="L2Titan" />
		<meta name="apple-mobile-web-app-title" content="L2Titan" />

		<!-- Favicon -->
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />

		<!-- DNS Prefetch for third-party domains -->
		<link rel="dns-prefetch" href="https://connect.facebook.net" />
		<link rel="dns-prefetch" href="https://www.facebook.com" />

		<!-- Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			rel="preload"
			as="style"
			href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700;900&family=Inter:wght@300;400;600&display=swap"
			onload="this.onload=null;this.rel='stylesheet'"
		/>
		<noscript>
			<link
				href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700;900&family=Inter:wght@300;400;600&display=swap"
				rel="stylesheet"
			/>
		</noscript>

		<meta name="generator" content={Astro.generator} />

		<!-- JSON-LD Structured Data -->
		<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
		<script type="application/ld+json" set:html={JSON.stringify(organizationLd)} />
		<script type="application/ld+json" set:html={JSON.stringify(gameServerLd)} />
		<script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />
		<style is:inline>
			body {
				opacity: 0;
				transition: opacity 0.1s ease-in;
			}
			body.i18n-ready,
			body.no-js {
				opacity: 1;
			}
		</style>
		<script is:inline define:vars={{ translationsJson }}>
			(function() {
				// Execute immediately before body renders
				const translationsData = JSON.parse(translationsJson);

				// Make functions globally available
				window.i18n = {
					getLanguage: function() {
						if (typeof localStorage === 'undefined') return 'es';
						const saved = localStorage.getItem('language');
						if (saved === 'es' || saved === 'en') return saved;
						// Default language for first visit
						return 'es';
					},
					getTranslation: function(key, lang) {
						const currentLang = lang || window.i18n.getLanguage();
						const keys = key.split('.');
						let value = translationsData[currentLang];
						
						for (const k of keys) {
							value = value?.[k];
							if (value === undefined) {
								console.warn('Translation key not found: ' + key);
								return key;
							}
						}
						
						return typeof value === 'string' ? value : key;
					},
					updateTranslations: function() {
						const lang = window.i18n.getLanguage();
						document.documentElement.lang = lang;
						const elements = document.querySelectorAll('[data-i18n]');
						
						elements.forEach((element) => {
							const key = element.getAttribute('data-i18n');
							if (key) {
								const translation = window.i18n.getTranslation(key, lang);
								if (element.tagName === 'INPUT' || element.tagName === 'TEXTAREA') {
									element.placeholder = translation;
								} else {
									element.textContent = translation;
								}
							}
						});

						// Update title attributes
						const titleElements = document.querySelectorAll('[data-i18n-title]');
						titleElements.forEach((element) => {
							const key = element.getAttribute('data-i18n-title');
							if (key) {
								element.setAttribute('title', window.i18n.getTranslation(key, lang));
							}
						});

						// Update alt attributes
						const altElements = document.querySelectorAll('[data-i18n-alt]');
						altElements.forEach((element) => {
							const key = element.getAttribute('data-i18n-alt');
							if (key) {
								element.alt = window.i18n.getTranslation(key, lang);
							}
						});

						// Update language indicator in navbar
						const langIndicator = document.getElementById('current-language');
						if (langIndicator) {
							langIndicator.textContent = lang.toUpperCase();
						}

						// Show body once translations are applied
						if (document.body) {
							document.body.classList.add('i18n-ready');
						}
					},
					setLanguage: function(lang) {
						if (typeof localStorage !== 'undefined') {
							localStorage.setItem('language', lang);
						}
						window.i18n.updateTranslations();
						// Dispatch custom event for other components
						window.dispatchEvent(new CustomEvent('languagechange', { detail: { language: lang } }));
					}
				};

				// Set initial language attribute immediately if document is available
				if (typeof document !== 'undefined' && document.documentElement) {
					const initialLang = window.i18n.getLanguage();
					document.documentElement.lang = initialLang;
				}
			})();
		</script>

		<!-- Meta Pixel Code -->
		<script is:inline>
			!function(f,b,e,v,n,t,s)
			{if(f.fbq)return;n=f.fbq=function(){n.callMethod?
			n.callMethod.apply(n,arguments):n.queue.push(arguments)};
			if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
			n.queue=[];t=b.createElement(e);t.async=!0;
			t.src=v;s=b.getElementsByTagName(e)[0];
			s.parentNode.insertBefore(t,s)}(window, document,'script',
			'https://connect.facebook.net/en_US/fbevents.js');
			fbq('init', '802270496211593');
			fbq('track', 'PageView');
		</script>
		<noscript><img height="1" width="1" style="display:none"
			src="https://www.facebook.com/tr?id=802270496211593&ev=PageView&noscript=1"
		/></noscript>
		<!-- End Meta Pixel Code -->
	</head>
	<body
		class="min-h-screen flex flex-col bg-black text-slate-200 overflow-x-hidden"
	>
		<Navbar />
		<main class="grow">
			<slot />
		</main>
		<Footer />
		<noscript>
			<style>
				body { opacity: 1 !important; }
			</style>
		</noscript>
		<script is:inline>
			// Apply translations synchronously immediately when body is parsed (before paint)
			(function() {
				if (window.i18n && typeof window.i18n.updateTranslations === 'function') {
					// Ensure html lang attribute is set based on detected language
					const lang = window.i18n.getLanguage();
					if (document.documentElement) {
						document.documentElement.lang = lang;
					}
					// Apply translations immediately - this executes synchronously before browser paints
					window.i18n.updateTranslations();
					// Ensure body is visible
					if (document.body) {
						document.body.classList.add('i18n-ready');
					}
				} else {
					// Fallback: show content if i18n system fails to initialize
					if (document.body) {
						document.body.classList.add('no-js');
					}
				}
			})();
		</script>
	</body>
</html>